{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "SigningKey": "",
    "AccessTokenLifetimeMinutes": 15
  },
  "Email": {
    "Provider": "Smtp",
    "FromAddress": "",
    "SmtpHost": "",
    "SmtpPort": 1025,
    "FrontendBaseUrl": "",
    "Resend": {
      "ApiKey": ""
    }
  },
  "Admin": {
    "Emails": ""
  },
  "Resilience": {
    "Outbound": {
      "Resend": {
        "AttemptTimeoutSeconds": 10,
        "TotalTimeoutSeconds": 30,
        "MaxRetryAttempts": 3,
        "BaseDelaySeconds": 2,
        "BreakerFailureRatio": 0.1,
        "BreakerMinimumThroughput": 5,
        "BreakerSamplingSeconds": 60,
        "BreakerDurationSeconds": 30
      }
    }
  }
}
