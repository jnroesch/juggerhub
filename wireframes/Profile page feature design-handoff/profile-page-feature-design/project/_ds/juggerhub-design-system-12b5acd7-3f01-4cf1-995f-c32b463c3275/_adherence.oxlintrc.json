        "selector": "JSXOpeningElement[name.name='PlayerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|photo|position|positions|team|since|isCaptain|href|key|ref|className|style|children)$/]",
        "message": "<PlayerCard> doesn't accept that prop. Declared props: name, photo, position, positions, team, since, isCaptain, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|tone|size|showLabel|label|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, tone, size, showLabel, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|secondary|highlight|success)$/]",
        "message": "<ProgressBar> tone must be one of 'primary' | 'secondary' | 'highlight' | 'success'."
