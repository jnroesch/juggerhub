{
  "folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {
      "PowerShell": {
        "source": "PowerShell",
        "icon": "terminal-powershell"
      },
      "Docker Compose Up": {
        "path": "pwsh.exe",
        "args": ["-NoExit", "-Command", "docker compose up --build -d; docker compose logs -f"],
        "icon": "play",
        "color": "terminal.ansiGreen"
      },
      "Docker Compose Debug": {
        "path": "pwsh.exe",
        "args": ["-NoExit", "-Command", "docker compose -f docker-compose.yml -f docker-compose.debug.yml up --build -d; docker compose -f docker-compose.yml -f docker-compose.debug.yml logs -f"],
        "icon": "debug-alt",
        "color": "terminal.ansiYellow"
      },
      "Docker Compose Down": {
        "path": "pwsh.exe",
        "args": ["-NoExit", "-Command", "docker compose down"],
        "icon": "debug-stop",
        "color": "terminal.ansiRed"
      },
      "claude-mem: Memory Viewer": {
        "path": "pwsh.exe",
        "args": ["-NoExit", "-Command", "npx --yes claude-mem start; Start-Process http://localhost:37777"],
        "icon": "history",
        "color": "terminal.ansiMagenta"
      },
      "Graphify: View Graph": {
        "path": "pwsh.exe",
        "args": ["-NoExit", "-Command", "Start-Process \"$PWD/graphify-out/graph.html\""],
        "icon": "graph",
        "color": "terminal.ansiGreen"
      },
      "Graphify: Rebuild + View": {
        "path": "pwsh.exe",
        "args": ["-NoExit", "-Command", "graphify update .; Start-Process \"$PWD/graphify-out/graph.html\""],
        "icon": "sync",
        "color": "terminal.ansiGreen"
      }
    }
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": ".NET Core Attach (Docker)",
        "type": "coreclr",
        "request": "attach",
        "processId": "${command:pickRemoteProcess}",
        "pipeTransport": {
          "pipeProgram": "docker",
          "pipeArgs": ["exec", "-i", "juggerhub-backend"],
          "debuggerPath": "/remote_debugger/vsdbg",
          "pipeCwd": "${workspaceFolder}",
          "quoteArgs": false
        },
        "sourceFileMap": {
          "/src": "${workspaceFolder}/backend"
        }
      },
      {
        "name": "Node.js Attach (Docker)",
        "type": "node",
        "request": "attach",
        "port": 9229,
        "address": "localhost",
        "localRoot": "${workspaceFolder}/frontend",
        "remoteRoot": "/app",
        "sourceMaps": true,
        "restart": true
      },
      {
        "name": "Chrome: Frontend",
        "type": "chrome",
        "request": "launch",
        "url": "http://localhost:3000",
        "webRoot": "${workspaceFolder}/frontend"
      }
    ],
    "compounds": [
      {
        "name": "Full Stack Debug",
        "configurations": [".NET Core Attach (Docker)", "Node.js Attach (Docker)", "Chrome: Frontend"]
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Docker Compose Up",
        "type": "shell",
        "command": "docker compose up --build -d",
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Docker Compose Debug",
        "type": "shell",
        "command": "docker compose -f docker-compose.yml -f docker-compose.debug.yml up --build -d",
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Docker Compose Down",
        "type": "shell",
        "command": "docker compose down",
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Docker Compose Logs",
        "type": "shell",
        "command": "docker compose logs -f",
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Docker Compose Down + Drop DB Volume",
        "detail": "Stop the stack and delete the Postgres volume (fresh database next `up`)",
        "type": "shell",
        "command": "docker compose down -v",
        "group": "build",
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Test: Backend (xUnit + Testcontainers)",
        "detail": "Run backend integration tests in a container (Docker must be running — Testcontainers spins up a sibling Postgres)",
        "type": "shell",
        "command": "docker compose -f docker-compose.yml -f docker-compose.test.yml run --rm backend-test",
        "group": "test",
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Test: Frontend (Jest)",
        "detail": "Run frontend unit tests in a container",
        "type": "shell",
        "command": "docker compose -f docker-compose.yml -f docker-compose.test.yml run --rm frontend-test",
        "group": "test",
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Test: E2E (Playwright)",
        "detail": "Run Playwright e2e (desktop + mobile) in a container; dependencies (frontend/backend/db/mailpit) start automatically",
        "type": "shell",
        "command": "docker compose -f docker-compose.yml -f docker-compose.test.yml run --rm playwright",
        "group": "test",
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Lint: Frontend (CI parity)",
        "detail": "Run the same lint gate as CI (`nx run-many -t lint`) in a container",
        "type": "shell",
        "command": "docker compose -f docker-compose.yml -f docker-compose.test.yml run --rm --entrypoint npx frontend-test nx run-many -t lint",
        "group": "test",
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "Install vsdbg",
        "type": "shell",
        "command": "docker exec -i juggerhub-backend bash -c 'curl -sSL https://aka.ms/getvsdbgsh | bash /dev/stdin -v latest -l /remote_debugger'",
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      },
      {
        "label": "🧠 claude-mem: Open Memory Viewer",
        "detail": "Start the claude-mem worker (idempotent) and open the web viewer at http://localhost:37777",
        "type": "shell",
        "command": "npx --yes claude-mem start; xdg-open http://localhost:37777",
        "windows": {
          "command": "npx --yes claude-mem start; Start-Process http://localhost:37777"
        },
        "osx": {
          "command": "npx --yes claude-mem start; open http://localhost:37777"
        },
        "icon": { "id": "history", "color": "terminal.ansiMagenta" },
        "problemMatcher": [],
        "presentation": { "reveal": "silent", "panel": "shared", "close": true }
      },
      {
        "label": "🕸️ Graphify: View Graph",
        "detail": "Open the interactive knowledge graph (graphify-out/graph.html) in your browser",
        "type": "shell",
        "command": "xdg-open \"${workspaceFolder}/graphify-out/graph.html\"",
        "windows": {
          "command": "Start-Process \"${workspaceFolder}/graphify-out/graph.html\""
        },
        "osx": {
          "command": "open \"${workspaceFolder}/graphify-out/graph.html\""
        },
        "icon": { "id": "graph", "color": "terminal.ansiGreen" },
        "problemMatcher": [],
        "presentation": { "reveal": "silent", "panel": "shared", "close": true }
      },
      {
        "label": "🕸️ Graphify: Rebuild + View Graph",
        "detail": "Run `graphify update .` (fast, no-LLM) then open the refreshed graph",
        "type": "shell",
        "command": "graphify update . ; xdg-open \"${workspaceFolder}/graphify-out/graph.html\"",
        "windows": {
          "command": "graphify update . ; Start-Process \"${workspaceFolder}/graphify-out/graph.html\""
        },
        "osx": {
          "command": "graphify update . ; open \"${workspaceFolder}/graphify-out/graph.html\""
        },
        "icon": { "id": "sync", "color": "terminal.ansiGreen" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated" }
      }
    ]
  }
}
