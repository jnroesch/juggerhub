# ----------------------------------------------------------------------------
# Environment variables for LOCAL development.
#
# Copy this file to `.env` (which is git-ignored), then adjust as needed:
#     Copy-Item .env.sample .env       # PowerShell
#     cp .env.sample .env              # bash
#
# docker-compose automatically loads `.env` for ${VAR} substitution. Copy this
# file to `.env` before your first `docker compose up` — the stack REQUIRES it:
# JWT_SIGNING_KEY has no built-in default, so `docker compose` refuses to start
# without a `.env`. The values below are working local defaults; edit as needed.
#
# NEVER commit the real `.env`. Dev/Prod secrets live in GitHub Environments and
# are injected by the deploy pipeline (see .specify/memory/constitution.md).
# ----------------------------------------------------------------------------

# --- PostgreSQL (docker-compose: database container + backend connection string) ---
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=postgres

# --- pgAdmin (docker-compose.debug.yml only) ---
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# --- Redis (feature 019: SignalR backplane + distributed rate limiting) ---
# The deployment runs more than one replica. Without a backplane each pod only reaches its own
# connections, so two players on different pods would see a dead conversation; and the rate
# limiter's counters would live per-pod, silently multiplying every limit by the replica count.
# Redis runs locally too, so local exercises the same fan-out path as Dev/Prod (constitution V:
# environments differ in configuration, never architecture).
# It stores no durable state — in-flight fan-out and one-minute counters only.
# Deployed environments set their own value in their GitHub Environment.
REDIS_CONNECTION=redis:6379

# ----------------------------------------------------------------------------
# Backend application config. .NET reads environment variables using the `__`
# nesting convention (e.g. Jwt__SigningKey -> Jwt:SigningKey). docker-compose.yml
# maps the variables below onto the backend container's configuration.
# ----------------------------------------------------------------------------

# ASP.NET environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development

# --- JWT (auth pipeline; see specs/002-authentication) ---
# Issuer/audience identify the token's origin and intended recipient.
JWT_ISSUER=juggerhub
JWT_AUDIENCE=juggerhub
# Signing key for HMAC-SHA256 JWTs. MUST be set (>= 32 bytes / 256 bits).
# Generate a strong value, e.g.:  openssl rand -base64 48
JWT_SIGNING_KEY=change-me-dev-only-please-generate-a-32+byte-random-secret
# Access token lifetime in minutes.
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15

# --- Email (transactional auth email; see specs/002-authentication) ---
# Local development captures ALL mail in Mailpit: SMTP host=mailpit, port=1025
# (hardcoded in docker-compose.yml), inbox UI at http://localhost:8025.
# Provider selects the sender: Smtp (local/Mailpit) or Resend (Dev/Prod).
EMAIL_PROVIDER=Smtp
# From address on outgoing auth emails.
EMAIL_FROM_ADDRESS=no-reply@juggerhub.local
# Base URL of the SPA, used to build verification / password-reset links in emails.
EMAIL_FRONTEND_BASE_URL=http://localhost:3000
# For Dev/Prod, set EMAIL_PROVIDER=Resend and supply an API key (NEVER commit a real key):
# EMAIL_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Platform admin allowlist (feature 012 — TEMPORARY gate; real role tracked in GH #21) ---
# Comma-separated emails treated as platform administrators. Admins can define, grant, and
# revoke badges & achievements. Enforced server-side by the PlatformAdmin authorization policy.
# Register an account with this email to act as the local admin. Deployed environments set
# their own value in their GitHub Environment.
ADMIN_EMAILS=admin@test.de

# --- Outbound resilience (feature 028; constitution Principle VII) ---
# Limits for calls to external services. Every value is OPTIONAL — omitting one falls back to a
# safe built-in default, never to "unlimited". Shape is identical in every environment; only the
# values may differ. Add a sibling block per new integration (Resilience__Outbound__<Name>__*).
# Time limit for a single attempt, and across all attempts together.
RESILIENCE_RESEND_ATTEMPT_TIMEOUT_SECONDS=10
RESILIENCE_RESEND_TOTAL_TIMEOUT_SECONDS=30
# Retries after the first try. Delays grow exponentially and are jittered.
RESILIENCE_RESEND_MAX_RETRY_ATTEMPTS=3
# Calls needed inside the sampling window before the circuit breaker evaluates its failure ratio.
# Deliberately LOW: the library default is 100 per window, which JuggerHub's email volume never
# reaches — a breaker that can never open is decorative. Derive this from real call volume.
RESILIENCE_RESEND_BREAKER_MIN_THROUGHPUT=5
